  "keyFeatures": [
    "Field promoter and supervisor tracking with real-time map visualization",
    "Route and establishment management with assignment workflows",
    "Role-based access control with granular permissions",
    "Dynamic form builder and survey management",
    "Inventory tracking with transfer and movement history",
    "Purchase order generation and management",
    "Photographic register for field documentation",
    "Multi-client and multi-region support",
    "SKU configuration for product catalogs",
    "Downloadable reports with analytics dashboard",
    "Firebase-backed authentication",
    "Template-based route planning"
  ],
